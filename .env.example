# =============================================================================
# AI 模拟面试系统 - 环境变量模板
# =============================================================================
# 使用方式：
#   cp .env.example .env
#   编辑 .env，填入真实值
#   .env 已被 .gitignore 忽略，永远不要提交到 git
#
# 本地开发快速启动（最少配置）：
#   只需要设置 JWT_SECRET，其他均有合理默认值。
#   建议用命令生成 secret：
#     python3 -c "import secrets; print(secrets.token_hex(64))"
#   或者：
#     openssl rand -hex 64
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# 必填项 - 没有默认值，必须显式设置
# ──────────────────────────────────────────────────────────────────────────────

# JWT 签名密钥（HS512 要求 >= 64 字节 = 128 hex chars）
# 每个环境使用不同的 secret，绝不共享
JWT_SECRET=your-secret-key-at-least-64-bytes-change-this-in-all-environments

# ──────────────────────────────────────────────────────────────────────────────
# 数据库（application.yml 中已设默认值，与 docker-compose.yml 对齐）
# ──────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=interview_db
DB_USER=interview
DB_PASSWORD=interview_dev_password

# ──────────────────────────────────────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Docker Compose 中 Redis 必须带密码（compose 默认 redis_dev_password，勿留空）。
# 本机直连非 Docker 的 Redis 且无密码时，可设为空并在 application.yml 保持默认。
REDIS_PASSWORD=redis_dev_password

# ──────────────────────────────────────────────────────────────────────────────
# Python Agent 服务
# ──────────────────────────────────────────────────────────────────────────────
AGENT_SERVICE_URL=http://localhost:8000
AGENT_SERVICE_TIMEOUT_MS=30000

# ──────────────────────────────────────────────────────────────────────────────
# Python Agent - LLM 配置（OpenAI 兼容接口）
# ──────────────────────────────────────────────────────────────────────────────
# 使用 OpenAI：
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# 使用 DeepSeek（兼容 OpenAI 接口）：
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────────────────────────
# Java 服务端口
# ──────────────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ──────────────────────────────────────────────────────────────────────────────
# CORS（允许跨域的前端地址，多个用逗号分隔）
# ──────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# JWT 有效期（毫秒）
# ──────────────────────────────────────────────────────────────────────────────
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=2592000000

# ──────────────────────────────────────────────────────────────────────────────
# 日志级别
# ──────────────────────────────────────────────────────────────────────────────
LOG_LEVEL_APP=DEBUG
