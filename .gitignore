# =============================================================================
# AI 模拟面试系统 - 根目录 .gitignore
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# ⚠️ 最重要：包含密钥和密码的文件，绝对不能提交
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ──────────────────────────────────────────────────────────────────────────────
# IDE / 编辑器
# ──────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.sublime-*

# ──────────────────────────────────────────────────────────────────────────────
# 操作系统
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────────────────────────────────────
# Java / Maven
# ──────────────────────────────────────────────────────────────────────────────
backend/target/
backend/*.jar
backend/*.war

# ──────────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────────
agent/__pycache__/
agent/**/__pycache__/
agent/*.pyc
agent/.venv/
agent/venv/
agent/.mypy_cache/
agent/.pytest_cache/

# ──────────────────────────────────────────────────────────────────────────────
# 日志与临时文件
# ──────────────────────────────────────────────────────────────────────────────
logs/
*.log
tmp/
temp/
